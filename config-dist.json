{
  "channels": [
    "#example"
  ],
  "server": "irc.example.net",
  "userName": "examplebot",
  "realName": "Example IRC Bot",
  "port": 6697,
  "debug": false,
  "showErrors": false,
  "autoRejoin": true,
  "autoConnect": false,
  "secure": true,
  "selfSigned": false,
  "certExpired": false,
  "floodProtection": true,
  "floodProtectionDelay": 1000,
  "sasl": false,
  "commandPrefix": "#",
  "bridges": {
    "discord": {
      "enabled": false,
      "ircNicks": [
        "ExampleBridgeUser"
      ],
      "pattern": "^<([^>]+)>\\s+(.+)$",
      "auth": {
        "enabled": false,
        "lookupUrl": "https://example.com/resolve-user-id",
        "method": "POST",
        "timeoutMs": 3000,
        "headerName": "x-example-secret",
        "headerValue": "change-me",
        "cacheTtlMs": 300000,
        "failureCacheTtlMs": 30000,
        "transportIdentity": {
          "enabled": true,
          "allowedNicks": [
            "ExampleBridgeUser"
          ],
          "allowedAccounts": [
            "ExampleBridgeUser"
          ],
          "allowWhoisFallback": true,
          "whoisTimeoutMs": 2000
        }
      }
    }
  },
  "http": {
    "enabled": true,
    "host": "0.0.0.0",
    "port": 8080,
    "baseDomain": "http://localhost:8080"
  },
  "dynamicCommands": {
    "webWrites": false
  },
  "luaSandbox": {
    "timeoutMs": 3500,
    "maxMessageLength": 420,
    "maxOutputLength": 2000
  }
}
