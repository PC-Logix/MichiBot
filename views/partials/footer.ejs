        </div>
      </div>
    </main>

    <nav>
      <div class="innertube">
        <h3>Navigation</h3>
        <% for (const item of nav) { %>
          <div class="nav-item"><a href="<%= item.href %>"><%= item.name %></a></div>
        <% } %>
      </div>
    </nav>
  </div>

  <footer>
    <div class="innertube">
      <p>Generated by <%= botNick %></p>
    </div>
  </footer>
</body>
</html>
